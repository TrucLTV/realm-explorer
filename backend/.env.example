# Realm Explorer — Backend Environment Variables
# Tạo file .env trong thư mục /backend và điền các giá trị này

# Database (Railway tự cấp khi bạn thêm PostgreSQL plugin)
DATABASE_URL=postgresql://username:password@host:port/dbname

# JWT Secret — tạo chuỗi ngẫu nhiên dài 32+ ký tự
JWT_SECRET=thay-bang-chuoi-bi-mat-cua-ban-it-nhat-32-ky-tu

# Mã giáo viên — dùng để tạo tài khoản học sinh
TEACHER_CODE=matkhau-giaovien-2024

# URL frontend (Vercel domain của bạn)
FRONTEND_URL=https://realm-explorer.vercel.app

# Môi trường
NODE_ENV=production
PORT=3000
